# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
CHATBOT_API_URL=http://127.0.0.1:8000/api/v1/chat

# Webhook Configuration
WEBHOOK_TOKEN=mysecretwebhooktoken
WEBHOOK_PORT=9000

# Redis (optional)
# REDIS_URL=redis://127.0.0.1:6379/0

# Processing Configuration
PROCESS_ASYNC=false
DEDUP_TTL=86400

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO

# LLM Configuration
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_MODEL=llama3
LLM_TIMEOUT=30
LLM_TEMPERATURE=0.2
OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=your_openai_key
# OPENAI_BASE_URL=https://api.openai.com/v1

# RAG Configuration
RAG_ENABLED=false
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_EMBEDDING_DIM=384
RAG_TOP_K=5
RAG_MIN_SCORE=0.2
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=100
RAG_USE_POSTGRES=false

# Agent ReAct
AGENT_REACT_ENABLED=false
AGENT_MAX_ITERATIONS=3

# Tools Configuration
SEARCH_API_URL=https://api.duckduckgo.com/
# SEARCH_API_KEY=
SEARCH_PROVIDER=duckduckgo
SEARCH_TIMEOUT=10

WEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather
# WEATHER_API_KEY=
WEATHER_UNITS=metric
WEATHER_LANG=es
WEATHER_TIMEOUT=10

HTTP_ALLOWED_HOSTS=
HTTP_TIMEOUT=10
HTTP_MAX_BYTES=2000
HTTP_FOLLOW_REDIRECTS=false

DATABASE_MAX_ROWS=20

# Admin Configuration
ADMIN_CHAT_IDS=

# ============================================
# ManagerBot Configuration (FASE 0-5)
# ============================================

# OPS Module (enabled by default)
MANAGER_ENABLE_OPS=true

# Enterprise Module (enabled by default)
MANAGER_ENABLE_ENTERPRISE=true
ENTERPRISE_ENABLED=true

# Agent Module (disabled by default - requires external service)
MANAGER_ENABLE_AGENT=false
AGENT_SERVICE_URL=http://localhost:8001

# ============================================
# Enterprise Features
# ============================================

ENTERPRISE_MODERATION_ENABLED=true
ENTERPRISE_OWNER_IDS=123456789
ENTERPRISE_FEATURE_FUN=true
ENTERPRISE_FEATURE_REACTIONS=true
ENTERPRISE_FEATURE_ANILIST=true
ENTERPRISE_FEATURE_WALLPAPER=true
ENTERPRISE_FEATURE_GETTIME=true
ENTERPRISE_DEFAULT_TIMEZONE=UTC

# External Services (optional)
# ENTERPRISE_SPAMWATCH_URL=https://staging-spamwatch
# ENTERPRISE_SPAMWATCH_TOKEN=your_token
# ENTERPRISE_SIBYL_URL=https://staging-sibyl
# ENTERPRISE_SIBYL_TOKEN=your_token
# ENTERPRISE_ANILIST_URL=https://graphql.anilist.co

# ============================================
# Database (optional)
# ============================================

# DATABASE_URL=postgresql://user:pass@localhost:5432/robot
# REDIS_URL=redis://localhost:6379/
